// alarm_panel_tile.slint — Phase 6 Wave 2 (TASK-105) tile for `type: alarm`.
//
// Renders a Home Assistant alarm_control_panel entity (security panels
// with disarmed / armed_* / pending / triggered states) with a
// three-state visual: idle (disarmed), active (any armed state), and
// triggered (visually distinct, accent colour). The Rust bridge produces
// an `AlarmTileVM` per alarm widget via
// `crate::ui::alarm::AlarmVM::from_entity` followed by a Slint-shape
// projection in `src/ui/bridge.rs::compute_alarm_tile_vm`.
//
// All colors come from theme tokens; no inline hex literals (CI hex-color
// gate, .github/workflows/ci.yml § Gate 1). Visual primitives only — no
// SVG-based icons in the tile body itself; the icon image is resolved by
// the Rust asset layer (TASK-010) and bound via `AlarmTileVM.icon`.
//
// View-model contract (see `src/ui/bridge.rs::AlarmTileVM`):
//   * The struct shape is mirrored 1:1 in Rust by the bridge. The Slint
//     compiler generates a Rust struct named `AlarmTileVM` whose fields
//     match these names with kebab→snake conversion.
//   * `state` is the canonical HA state string: `"disarmed"`,
//     `"armed_home"`, `"armed_away"`, `"armed_night"`, `"armed_vacation"`,
//     `"armed_custom_bypass"`, `"pending"`, `"triggered"`,
//     `"unavailable"`. Anything else is treated as unavailable by the
//     colour fallback.
//   * `is-armed` is precomputed by `AlarmVM::from_entity` (true for any
//     `armed_*` state) so the Slint side does not branch on the
//     state-string vocabulary.
//   * `is-triggered` is precomputed (true only for `"triggered"`) — drives
//     the distinct triggered visual (accent colour, full opacity).
//   * `pending` (HA-state, NOT the per-tile spinner) is precomputed; not a
//     stored bool to keep the struct aligned with the lock/cover/fan
//     pattern.
//   * `placement` is a NESTED struct (`AlarmTilePlacement`) for 1:1
//     mapping with `dashboard::schema::Placement` in Rust.
//
// Three-state render (per Phase 6 plan acceptance):
//   * idle (state == "disarmed")        — text-secondary icon tint, full opacity.
//   * active (is-armed == true)         — state-on icon tint, full opacity.
//   * triggered (is-triggered == true)  — accent icon tint, full opacity.
//   * unavailable                       — state-unavailable tint, reduced opacity (0.5).
//
// AnimationBudget integration:
//   * Press feedback inherited from CardBase. Active-count mutation
//     deferred to Phase 3 (no specific ticket yet); the bridge will
//     wire increment/decrement around the press timer it owns. See
//     ui/slint/light_tile.slint:23-32 for the canonical deferral
//     rationale.
//
// Out of scope (TASK-105 dispatcher wiring):
//   * Arm-mode buttons / disarm button visual design — owned by
//     `AlarmBody` more-info modal (TASK-105 acceptance #6); the tile
//     shows the current state as label only and forwards gestures to
//     CardBase (no tile-level TouchArea).
//   * PIN entry modal — TASK-100 owns the standalone PIN entry component;
//     the dispatcher (TASK-105 dispatcher wiring in
//     `src/actions/dispatcher.rs::dispatch_alarm_arm_or_disarm`) calls
//     `PinEntryHost::request_pin` on the `RequiredOnDisarm` policy when
//     the user taps Disarm.

import { Theme } from "theme.slint";
import { CardBase } from "card_base.slint";

// Computed grid placement, mirrors `dashboard::schema::Placement` in Rust.
// Re-declared per tile file for self-documentation; identical to
// `LightTilePlacement` / `SensorTilePlacement` / `EntityTilePlacement` /
// `CoverTilePlacement` / `FanTilePlacement`.
export struct AlarmTilePlacement {
    col: int,
    row: int,
    span-cols: int,
    span-rows: int,
}

// Typed view-model for an alarm panel tile.
//
// Field semantics:
//   * name           — user-visible entity label (friendly_name fallback to id).
//   * state          — canonical HA state string (`"disarmed"`,
//                      `"armed_home"`, `"armed_away"`, `"armed_night"`,
//                      `"armed_vacation"`, `"armed_custom_bypass"`,
//                      `"pending"`, `"triggered"`, `"unavailable"`).
//   * is-armed       — derived: true for any `armed_*` state.
//   * is-triggered   — derived: true only for `"triggered"`.
//   * is-pending     — derived: true only for `"pending"` (HA-state pending,
//                      distinct from the per-tile spinner gate `pending`).
//   * icon-id        — design-token id (e.g. "mdi:shield"); resolved
//                      to bytes by the asset layer (TASK-010).
//   * icon           — resolved Slint image written by the bridge (TASK-015).
//   * preferred-columns / preferred-rows — author intent from YAML, used
//                      by the grid packer (TASK-014).
//   * placement      — packed grid coordinates and span. Static this phase.
//   * pending        — true while an OptimisticEntry exists for this tile's
//                      entity. Drives the per-tile spinner overlay on
//                      CardBase (TASK-067), bound from
//                      `LiveStore::pending_for_widget(widget_id)`.
//                      DISTINCT from `is-pending` (HA-state) above.
export struct AlarmTileVM {
    name: string,
    state: string,
    is-armed: bool,
    is-triggered: bool,
    is-pending: bool,
    icon-id: string,
    icon: image,
    preferred-columns: int,
    preferred-rows: int,
    placement: AlarmTilePlacement,
    pending: bool,
}

// AlarmPanelTile — wraps CardBase with the alarm-panel-specific content layout.
//
// Press feedback and gesture detection both live on CardBase (TASK-060):
// the single TouchArea inside CardBase captures pointer events for the
// whole tile and exposes `pressed` as an out-property this tile reads
// for visual feedback. Tile-level TouchAreas were removed to avoid
// double-capture (Risk #4).
export component AlarmPanelTile inherits Rectangle {
    in property <AlarmTileVM> view-model;

    // Resolved state colour. Branches on the precomputed booleans first
    // (triggered / armed) and falls back to the state-string match for the
    // remaining cases. No inline hex literals; every branch picks a token
    // from `Theme`. Triggered uses the accent token to give a visually
    // distinct "alarm fired" appearance per the TASK-105 brief.
    property <color> state-color:
        view-model.state == "unavailable" ? Theme.state-unavailable
        : view-model.is-triggered ? Theme.accent
        : view-model.is-armed ? Theme.state-on
        : Theme.state-off;

    // Reduce opacity for the unavailable visual state (Phase 6 plan
    // three-state render acceptance). Idle, active, and triggered render
    // at full opacity; only unavailable dims.
    opacity: view-model.state == "unavailable" ? 0.5 : 1.0;

    base := CardBase {
        // Bind the per-tile pending-spinner gate (TASK-067). The Rust
        // bridge writes `view-model.pending` from
        // `LiveStore::pending_for_widget` (TASK-064 read API) on each
        // refresh; this property feeds the spinner overlay declared on
        // CardBase. Slint MUST read only this property — there is no
        // parallel pending-state path (Risk #14).
        pending: view-model.pending;

        VerticalLayout {
            spacing: Theme.space-2;

            // Header row: icon + entity name. Icon is tinted with the
            // resolved state colour so a glance at the tile reveals
            // disarmed/armed/triggered status.
            HorizontalLayout {
                spacing: Theme.space-2;
                alignment: start;

                Image {
                    source: view-model.icon;
                    width: Theme.font-xl;
                    height: Theme.font-xl;
                    colorize: state-color;
                }

                Text {
                    text: view-model.name;
                    color: Theme.text-primary;
                    font-size: Theme.font-md;
                    font-weight: Theme.font-weight-medium;
                    vertical-alignment: center;
                }
            }

            // State value, displayed in the state colour for redundancy
            // with the icon tint (accessibility: do not rely on colour
            // alone). Alarm state strings can be longer ("armed_custom_bypass")
            // so font-md is the right hero size — sensor-tile-like
            // font-xxl would push the value off the card.
            Text {
                text: view-model.state;
                color: state-color;
                font-size: Theme.font-md;
                font-weight: Theme.font-weight-bold;
            }
        }
    }
}
