# === Rust build artifacts ===
target/
**/*.rs.bk
*.pdb

# === Environment / secrets ===
.env
.env.local
.env.*.local
*.key
*.pem
*.crt
secrets/

# === Editor / OS ===
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# === Logs ===
*.log
logs/

# === Claude Code local files ===
.claude/settings.local.json
.claude/projects/
.claude/.credentials.json
.claude/cache/
.claude/.cache/
.claude/shell-snapshots/
.claude/todos/
.claude/worktrees/

# === opencode local files ===
.opencode/node_modules/
.opencode.json
# === Local governance/planning workspace (this-machine-only dev) ===
docs/
.leap/

# ops/ is local-only by default, but specific scripts are shippable infrastructure
# (CI gates / pre-receive hooks called out as protected paths in CLAUDE.md).
# Pattern: ignore everything under ops/, then explicitly un-ignore the files
# CI/pre-receive depends on.
ops/*
!ops/checks/
!ops/pre-receive/
!ops/ha/
ops/checks/*
ops/pre-receive/*
!ops/checks/coverage-ratchet.js
!ops/checks/__tests__/
!ops/checks/forbidden-tokens.sh
!ops/pre-receive/test-deletion.sh
# ops/ha/ contents are tracked; HA runtime writes are filtered by ops/ha/.gitignore.
# === Coverage tooling outputs (coverage/baseline.json is the only tracked file) ===
coverage/*.profraw
coverage/lcov.info
coverage/.coverage
coverage/html/

# === VM artifacts (large / secret) ===
vm/base.qcow2
vm/disk.qcow2
vm/seed.iso
vm/SHA512SUMS
vm/known_hosts
vm/keys/id_ed25519
