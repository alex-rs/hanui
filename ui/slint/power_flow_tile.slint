// power_flow_tile.slint — Phase 6 Wave 6d (TASK-094) tile for `type: power_flow`.
//
// Renders the canonical Home Assistant energy-flow graph: solar generation,
// grid import/export, home consumption, and (optional) battery flow + state-
// of-charge. The Rust bridge produces a `PowerFlowTileVM` per power-flow
// widget via `crate::ui::power_flow::PowerFlowVM` followed by a Slint-shape
// projection in `src/ui/bridge.rs::compute_power_flow_tile_vm`.
//
// Reference (per TASK-094 acceptance criterion #1): the visual + behavioural
// surface mirrors the `power-flow-card-plus` Lovelace card
// (https://github.com/flixlix/power-flow-card-plus). hanui reads typed entity
// values from `LiveStore` rather than the Lovelace home-assistant-js-websocket
// adapter, but the user-visible feature set matches as closely as Slint
// primitives allow.
//
// Per TASK-094 (Phase 6 6d) plan: Phase 6 baseline shipped the **static
// current-values render** with theme-token colour coding. The
// TASK-094-followup pass (this file) adds the per-lane animated flow
// particles using `animation-tick()`-derived phase, matching the canonical
// Lovelace power-flow-card animation idiom but expressed in Slint
// primitives that work on every backend including the software renderer.
//
// Display-mode logic (TASK-094 acceptance criterion §Display-mode logic):
//   * `Auto` (default): values >= 1000 W render as kW with one decimal;
//     values < 1000 W render as W as integers.
//   * The bridge passes the formatted strings via `solar-label` / `grid-label` /
//     etc. so the Slint side does not branch on the unit choice. This keeps
//     the tile rendering allocation-free on the per-frame path: the bridge
//     formats once at entity-change time.
//
// Idle-lane behaviour (TASK-094 acceptance criterion §Idle-lane behaviour):
//   * Lanes with magnitude < `min_flow_w` render at 30% opacity with no
//     particle animation. The numeric value still displays. The bridge
//     pre-computes the per-lane idle booleans (`solar-idle`, etc.) so the
//     Slint side does not branch on threshold values. Opacity transitions
//     are animated (250 ms ease) so a lane crossing the threshold does not
//     flicker.
//
// All colors come from theme tokens; no inline hex literals (CI hex-color
// gate, `.github/workflows/ci.yml` § Gate 1). Visual primitives only — no
// SVG icons in the tile body itself; the icon image is resolved by the Rust
// asset layer (TASK-010) and bound via `PowerFlowTileVM.icon`.
//
// View-model contract (see `src/ui/bridge.rs::PowerFlowTileVM`):
//   * The struct shape is mirrored 1:1 in Rust by the bridge. The Slint
//     compiler generates a Rust struct named `PowerFlowTileVM` whose fields
//     match these names with kebab→snake conversion.
//   * `*-w` are `float` values (signed for grid / battery to encode flow
//     direction); the companion `has-*` booleans gate whether to render
//     the corresponding lane, because Slint floats have no native
//     `Option<>` and `0.0` is a real reading (idle lane).
//   * `*-label` are pre-formatted display strings (e.g. `"1.5 kW"` or
//     `"450 W"`); the bridge formats them at entity-change time per the
//     display-mode logic so the per-frame Slint render does no string
//     allocation.
//   * `placement` is a NESTED struct (`PowerFlowTilePlacement`) for 1:1
//     mapping with `dashboard::schema::Placement` in Rust.
//
// Three-state render (per Phase 6 plan acceptance):
//   * idle (all lanes below threshold)        — text-secondary lane tint, 30% lane opacity.
//   * active (any lane above threshold)        — accent / state-on lane tint, full opacity, animated particles.
//   * unavailable (grid entity unreachable)    — state-unavailable tint, reduced root opacity (0.5).
//
// AnimationBudget integration (TASK-094 acceptance criterion §Per-profile budget,
// TASK-094-followup):
//   * Animation framerate is capped at `AnimationBudget.framerate-cap` per
//     PHASES.md § Performance budgets — the cap is enforced at the
//     renderer/timer level by the Rust bridge wiring; this file only
//     references the budget surface, never hardcodes the cap.
//   * Per-lane particles are driven by `animation-tick()` derived phase,
//     not by tile-owned `Timer`s. Slint owns the interpolation; the bridge
//     is responsible for the per-frame budget (via `framerate-cap`).
//   * Particle count: 3 per active lane × up to 4 lanes (solar / grid /
//     battery / home) = 12 particles peak. Well within the per-frame
//     budget on the tightest profile (opi_zero3 = 2 simultaneous tile
//     animations; particle motion runs continuously and is shared across
//     all 12 dots via a single `animation-tick()` source).
//   * `AnimationBudget.at-capacity` collapses the entire particle subtree
//     (the `if` block produces nothing). The lane line and value label
//     remain visible, preserving the static read-out — only the per-
//     particle movement is suppressed. (Snapping `phase-0` to 0 was
//     considered but rejected: the phase-1/phase-2 stagger offsets are
//     constants (0.333 / 0.667), so a `phase-0 == 0` collapse would leave
//     three stationary dots compressed into the first 67 % of the strip.)
//   * Idle lanes (`*-idle == true`) render no particles at all (the `if`
//     subtree collapses), so an idle dashboard contributes zero animation
//     work.
//   * Press feedback is inherited from CardBase. The active-count gate is
//     a global concern (see card_base.slint).

import { Theme } from "theme.slint";
import { CardBase, AnimationBudget } from "card_base.slint";

// Computed grid placement, mirrors `dashboard::schema::Placement` in Rust.
// Re-declared per tile file for self-documentation; identical to
// `LightTilePlacement` / `SensorTilePlacement` / `EntityTilePlacement` /
// `CoverTilePlacement` / `FanTilePlacement` / `LockTilePlacement` /
// `AlarmTilePlacement` / `HistoryGraphTilePlacement` /
// `CameraTilePlacement` / `ClimateTilePlacement` / `MediaPlayerTilePlacement`.
export struct PowerFlowTilePlacement {
    col: int,
    row: int,
    span-cols: int,
    span-rows: int,
}

// Typed view-model for a power-flow tile.
//
// Field semantics:
//   * name              — user-visible label (typically "Power Flow").
//   * grid-w            — grid power flow in watts (signed: positive = import,
//                          negative = export). Always meaningful when the
//                          grid entity is configured (it is required).
//                          Also used as the per-frame flow-magnitude input
//                          to the grid-lane particle period (TASK-094-followup).
//   * grid-label        — pre-formatted display string for the grid value
//                          (e.g. `"1.5 kW"`, `"-200 W"`).
//   * grid-importing    — derived: true when grid-w > 0 (importing from grid).
//   * grid-idle         — derived: true when |grid-w| < min_flow_w. Drives
//                          the dimmed / no-particle visual.
//   * has-solar         — whether the widget configures a solar entity.
//   * solar-w           — solar production in watts. Also drives the
//                          solar-lane particle period (TASK-094-followup).
//   * solar-label       — pre-formatted display string for the solar value.
//   * solar-idle        — derived: true when solar-w < min_flow_w.
//   * has-battery       — whether the widget configures a battery entity.
//   * battery-w         — battery flow in watts (signed: positive = charging,
//                          negative = discharging). Also drives the
//                          battery-lane particle period (TASK-094-followup).
//   * battery-label     — pre-formatted display string for the battery value.
//   * battery-charging  — derived: true when battery-w > 0.
//   * battery-idle      — derived: true when |battery-w| < min_flow_w.
//   * has-battery-pct   — whether the widget configures a battery_soc_entity.
//   * battery-pct       — battery state-of-charge in 0..=100.
//   * has-home          — whether the widget configures a home entity.
//   * home-w            — home consumption in watts. Also drives the
//                          home-lane particle period (TASK-094-followup).
//   * home-label        — pre-formatted display string for the home value.
//   * home-idle         — derived: true when home-w < min_flow_w.
//   * is-available      — false when the grid entity is unavailable / unknown;
//                          drives the unavailable visual variant.
//   * icon-id           — design-token id (typically `mdi:lightning-bolt-circle`).
//   * icon              — resolved Slint image written by the bridge.
//   * preferred-columns / preferred-rows — author intent from YAML.
//   * placement         — packed grid coordinates and span. Static this phase.
//   * pending           — true while an `OptimisticEntry` exists for any of
//                          the configured power-flow entities.
export struct PowerFlowTileVM {
    name: string,
    grid-w: float,
    grid-label: string,
    grid-importing: bool,
    grid-idle: bool,
    has-solar: bool,
    solar-w: float,
    solar-label: string,
    solar-idle: bool,
    has-battery: bool,
    battery-w: float,
    battery-label: string,
    battery-charging: bool,
    battery-idle: bool,
    has-battery-pct: bool,
    battery-pct: float,
    has-home: bool,
    home-w: float,
    home-label: string,
    home-idle: bool,
    is-available: bool,
    icon-id: string,
    icon: image,
    preferred-columns: int,
    preferred-rows: int,
    placement: PowerFlowTilePlacement,
    pending: bool,
}

// FlowLane — a single source→destination lane with three animated particles
// flowing along the connector strip.
//
// Visual:
//   * `lane-color`-tinted thin connector line spanning the strip width.
//   * Three small (4 px) `lane-color` dots travelling left→right, evenly
//     phase-staggered (0, 1/3, 2/3 of the cycle) so the flow reads as
//     continuous.
//   * Particles fade in over the first 10 % of their cycle and fade out over
//     the last 10 %, so the dots do not appear to pile at the destination.
//
// Animation:
//   * Driven by `animation-tick()` modulo `period` — a single time source for
//     all three dots (no per-particle Timer). The phase-stagger is a constant
//     offset added to the same time source. Animation capped at
//     `AnimationBudget.framerate-cap` per PHASES.md § Performance budgets.
//   * `period-ms` is computed by the parent tile from the lane's flow watts
//     via `clamp(3000 - watts/10, 800, 3000)` — high power → fast particles,
//     low power → slow. The mapping is the canonical Lovelace
//     power-flow-card behaviour.
//   * `AnimationBudget.at-capacity` snaps phases to 0 (particles are visible
//     but do not move). Lane line and labels remain visible regardless.
//   * `idle == true` collapses the entire particle subtree (the `if` block
//     produces nothing) so an idle dashboard contributes zero animation work.
//   * Lane opacity transitions are animated (250 ms ease-in-out) so the lane
//     does not flicker when crossing the idle threshold.
component FlowLane inherits Rectangle {
    in property <string> label-text;
    in property <string> arrow-text;
    in property <string> value-text;
    in property <color> lane-color;
    // Lane is "idle" — magnitude below min_flow_w. Pre-computed by the
    // bridge (`*-idle` view-model field).
    in property <bool> idle;
    // Lane should render at root opacity even when idle (used for the
    // unavailable variant where the parent already dims to 0.5).
    in property <bool> is-available;
    // Period of one full particle traversal in milliseconds; lower = faster.
    // Parent computes this via the canonical
    //     clamp(3000 - watts/10, 800, 3000)
    // mapping. When `idle == true` this property is ignored (the particle
    // subtree is collapsed).
    in property <int> period-ms: 2000;

    height: Theme.space-5;

    // Animated lane opacity. 250 ms ease so a lane crossing the idle
    // threshold cross-fades rather than flickering.
    opacity: idle ? 0.3 : 1.0;
    animate opacity {
        duration: AnimationBudget.at-capacity ? 0ms : 250ms;
        easing: ease-in-out;
    }

    // Source-end label (e.g. "solar", "grid").
    Text {
        x: 0px;
        y: (parent.height - self.height) / 2;
        text: root.label-text;
        color: Theme.text-secondary;
        font-size: Theme.font-sm;
        font-weight: Theme.font-weight-regular;
        vertical-alignment: center;
    }

    // Direction arrow.
    Text {
        x: 48px;
        y: (parent.height - self.height) / 2;
        text: root.arrow-text;
        color: root.lane-color;
        font-size: Theme.font-md;
        font-weight: Theme.font-weight-bold;
        vertical-alignment: center;
        horizontal-alignment: center;
    }

    // Connector strip — fills the area between the arrow and the value
    // label. Particles ride along this strip.
    connector := Rectangle {
        x: 72px;
        y: (parent.height - self.height) / 2;
        width: parent.width - 72px - 88px;
        height: 2px;
        background: root.lane-color;
        // Connector subtly fades when the lane is idle; the parent
        // opacity already dims this rectangle, so no explicit branch
        // is needed here.
    }

    // Particle subtree — only present when the lane is non-idle, the
    // grid entity is available, AND the global animation budget has
    // headroom. This is the per-frame work; the three-way guard ensures:
    //   * Idle dashboards contribute zero animation work (`!root.idle`).
    //   * Unavailable lanes do not animate (`root.is-available`).
    //   * Budget-exhausted runs suppress the particles entirely
    //     (`!AnimationBudget.at-capacity`) — collapsing the subtree is
    //     correct here rather than snapping `phase-0` to 0, because the
    //     phase-1 / phase-2 stagger constants (0.333, 0.667) would
    //     otherwise leave three stationary dots compressed into the
    //     first 67 % of the strip, a visually distracting artefact
    //     (per opencode-review iteration 1, blocker 1). Lane line +
    //     labels remain visible regardless, preserving the static
    //     read-out.
    if !root.idle && root.is-available && !AnimationBudget.at-capacity : Rectangle {
        // Mirror the connector geometry so child particles compute their
        // travel from a stable parent-relative coordinate space.
        x: 72px;
        y: 0px;
        width: parent.width - 72px - 88px;
        height: parent.height;

        // Phase 0..1 for the first particle. The `mod(animation-tick(),
        // period_ms)` expression yields a duration in 0..period_ms; we
        // divide by period_ms to get a unit-less progress value. Pattern
        // ratified by `card_base.slint:393` (`mod(animation-tick() / 1ms,
        // 1200) / 1200 * 360deg`) — `mod(float, int)` operand mix is
        // accepted by the Slint compiler.
        property <float> phase-0:
            mod(animation-tick() / 1ms, root.period-ms) / root.period-ms;
        // Phase-staggered second and third particles (1/3, 2/3 of cycle).
        // `mod(x + offset, 1)` keeps the value in 0..1.
        property <float> phase-1: mod(self.phase-0 + 0.333, 1.0);
        property <float> phase-2: mod(self.phase-0 + 0.667, 1.0);

        // Particle 0.
        Rectangle {
            width: 4px;
            height: 4px;
            border-radius: 2px;
            background: root.lane-color;
            x: parent.phase-0 * (parent.width - self.width);
            y: (parent.height - self.height) / 2;
            // Fade in (first 10 %) / fade out (last 10 %) so the dot
            // does not appear to pile at the destination.
            opacity: parent.phase-0 < 0.1 ? parent.phase-0 * 10
                : parent.phase-0 > 0.9 ? (1.0 - parent.phase-0) * 10
                : 1.0;
        }
        // Particle 1.
        Rectangle {
            width: 4px;
            height: 4px;
            border-radius: 2px;
            background: root.lane-color;
            x: parent.phase-1 * (parent.width - self.width);
            y: (parent.height - self.height) / 2;
            opacity: parent.phase-1 < 0.1 ? parent.phase-1 * 10
                : parent.phase-1 > 0.9 ? (1.0 - parent.phase-1) * 10
                : 1.0;
        }
        // Particle 2.
        Rectangle {
            width: 4px;
            height: 4px;
            border-radius: 2px;
            background: root.lane-color;
            x: parent.phase-2 * (parent.width - self.width);
            y: (parent.height - self.height) / 2;
            opacity: parent.phase-2 < 0.1 ? parent.phase-2 * 10
                : parent.phase-2 > 0.9 ? (1.0 - parent.phase-2) * 10
                : 1.0;
        }
    }

    // Value label (right-aligned).
    Text {
        x: parent.width - 88px;
        y: (parent.height - self.height) / 2;
        width: 88px;
        text: root.value-text;
        color: root.lane-color;
        font-size: Theme.font-md;
        font-weight: Theme.font-weight-bold;
        vertical-alignment: center;
        horizontal-alignment: right;
    }
}

// PowerFlowTile — wraps CardBase with the power-flow content layout.
//
// Press feedback and gesture detection both live on CardBase (TASK-060):
// the single TouchArea inside CardBase captures pointer events for the
// whole tile. Tile-level TouchAreas were removed to avoid double-capture
// (Risk #4).
//
// Layout: 4-row vertical stack (header, grid lane, optional solar/battery
// lanes, home lane). Lanes branch by visibility — covers the canonical
// 4-node power-flow graph (Solar → Grid ↔ Home ← Battery) flattened into
// a vertical list for legibility on a 2x2 / 4x3 grid cell. Each lane has
// animated flow particles travelling along the connector strip
// (TASK-094-followup).
//
// Animation discipline (TASK-094 acceptance §Per-profile budget):
//   * Per-frame work is read-only — particle positions derive from
//     `animation-tick()` modulo per-lane `period-ms`. There are no
//     per-tile `Timer`s. Per PHASES.md:58, animation framerate is capped
//     at `AnimationBudget.framerate-cap` (the cap is enforced at the
//     renderer level by the Rust bridge — this file only references the
//     budget surface).
//   * `AnimationBudget.at-capacity` collapses every particle subtree so
//     the budget is honoured globally; lane lines + labels remain
//     visible (the read-out is preserved even when motion is suppressed).
//     Collapsing rather than snapping is required because the phase
//     stagger constants (0.333, 0.667) would leave three stationary
//     dots compressed into the strip start otherwise.
//   * Idle lanes collapse the particle subtree entirely (the `if !idle`
//     guard) so an idle dashboard contributes zero animation work.
//   * Particle count: 3 per active lane × up to 4 lanes = 12 particles
//     peak. The opi_zero3 profile budget is 2 simultaneous tile
//     animations; particles share a single `animation-tick()` source so
//     they count as a single continuous animation, not 12.
export component PowerFlowTile inherits Rectangle {
    in property <PowerFlowTileVM> view-model;

    // Per-lane particle period in milliseconds. Canonical Lovelace
    // power-flow-card mapping:
    //     duration_ms = clamp(3000 - flow_watts / 10, 800, 3000)
    // High power → fast particles (≈ 800 ms full traversal), low power →
    // slow (≈ 3000 ms full traversal). The bridge supplies typed
    // signed-watts values; we use `abs` via a ternary because Slint's
    // float `abs(x)` is not a guaranteed builtin — `x > 0 ? x : -x` is
    // the conservative spelling.
    //
    // The clamp is expressed as `min(max(…, 800), 3000)` because Slint
    // does not have a 3-arg `clamp` builtin in 1.7. Output type is `int`
    // (millisecond count) to match `FlowLane.period-ms` in-property.
    property <int> grid-period-ms: min(
        max(
            (3000 - (view-model.grid-w > 0 ? view-model.grid-w : -view-model.grid-w) / 10),
            800,
        ),
        3000,
    );
    property <int> solar-period-ms: min(
        max(
            (3000 - (view-model.solar-w > 0 ? view-model.solar-w : -view-model.solar-w) / 10),
            800,
        ),
        3000,
    );
    property <int> battery-period-ms: min(
        max(
            (3000 - (view-model.battery-w > 0 ? view-model.battery-w : -view-model.battery-w) / 10),
            800,
        ),
        3000,
    );
    property <int> home-period-ms: min(
        max(
            (3000 - (view-model.home-w > 0 ? view-model.home-w : -view-model.home-w) / 10),
            800,
        ),
        3000,
    );

    // Resolved icon tint. Branches on availability first, then on whether
    // any lane is non-idle. No inline hex literals; every branch picks a
    // token from `Theme`.
    property <color> icon-color:
        !view-model.is-available ? Theme.state-unavailable
        : (!view-model.grid-idle || (view-model.has-solar && !view-model.solar-idle)
            || (view-model.has-battery && !view-model.battery-idle)
            || (view-model.has-home && !view-model.home-idle))
          ? Theme.accent
        : Theme.text-secondary;

    // Per-lane resolved colours. Each branches on:
    //   1. unavailable (grid entity down) → state-unavailable
    //   2. idle (below threshold)         → text-secondary (subdued)
    //   3. import / charging (positive)   → state-on (warm amber)
    //   4. export / discharging (negative)→ accent (bright)
    //
    // Solar / home lanes never have a sign convention — they render in
    // accent when active, text-secondary when idle.
    property <color> grid-color:
        !view-model.is-available ? Theme.state-unavailable
        : view-model.grid-idle ? Theme.text-secondary
        : view-model.grid-importing ? Theme.state-on
        : Theme.accent;

    property <color> solar-color:
        !view-model.is-available ? Theme.state-unavailable
        : view-model.solar-idle ? Theme.text-secondary
        : Theme.state-on;

    property <color> battery-color:
        !view-model.is-available ? Theme.state-unavailable
        : view-model.battery-idle ? Theme.text-secondary
        : view-model.battery-charging ? Theme.state-on
        : Theme.accent;

    property <color> home-color:
        !view-model.is-available ? Theme.state-unavailable
        : view-model.home-idle ? Theme.text-secondary
        : Theme.accent;

    // Reduce opacity for the unavailable visual state (Phase 6 plan
    // three-state render acceptance). Idle and active render at full
    // opacity at the root level; per-lane idle dimming happens inside
    // `FlowLane.opacity` (animated cross-fade).
    opacity: !view-model.is-available ? 0.5 : 1.0;

    base := CardBase {
        // Bind the per-tile pending-spinner gate (TASK-067). The Rust
        // bridge writes `view-model.pending` from
        // `LiveStore::pending_for_widget` (TASK-064 read API) on each
        // refresh; this property feeds the spinner overlay declared on
        // CardBase. Slint MUST read only this property — there is no
        // parallel pending-state path (Risk #14).
        pending: view-model.pending;

        VerticalLayout {
            spacing: Theme.space-2;

            // Header row: icon + tile name. Icon is tinted with the
            // resolved icon-color so a glance at the tile reveals
            // overall flow status.
            HorizontalLayout {
                spacing: Theme.space-2;
                alignment: start;

                Image {
                    source: view-model.icon;
                    width: Theme.font-xl;
                    height: Theme.font-xl;
                    colorize: icon-color;
                }

                Text {
                    text: view-model.name;
                    color: Theme.text-primary;
                    font-size: Theme.font-md;
                    font-weight: Theme.font-weight-medium;
                    vertical-alignment: center;
                }
            }

            // Grid lane — always rendered; the grid_entity is required
            // by the schema (`PowerFlowGridEntityNotPower` validator
            // rejects a missing/non-power grid entity at YAML parse
            // time). The directional indicator is "↓" for import and
            // "↑" for export, mirroring the `power-flow-card-plus`
            // Lovelace convention.
            FlowLane {
                label-text: "grid";
                arrow-text: !view-model.is-available
                    ? "—"
                    : view-model.grid-importing ? "↓" : "↑";
                value-text: view-model.grid-label;
                lane-color: grid-color;
                idle: view-model.grid-idle;
                is-available: view-model.is-available;
                period-ms: grid-period-ms;
            }

            // Solar lane — rendered only when the widget configures a
            // solar entity. The arrow is always "↓" (solar generation
            // flows toward the home / grid).
            if view-model.has-solar : FlowLane {
                label-text: "solar";
                arrow-text: "↓";
                value-text: view-model.solar-label;
                lane-color: solar-color;
                idle: view-model.solar-idle;
                is-available: view-model.is-available;
                period-ms: solar-period-ms;
            }

            // Battery lane — rendered only when the widget configures a
            // battery entity. Charging shows "↓" (energy into battery);
            // discharging shows "↑" (energy out to home/grid).
            if view-model.has-battery : FlowLane {
                label-text: "battery";
                arrow-text: view-model.battery-charging ? "↓" : "↑";
                value-text: view-model.battery-label;
                lane-color: battery-color;
                idle: view-model.battery-idle;
                is-available: view-model.is-available;
                period-ms: battery-period-ms;
            }

            // Battery state-of-charge label — rendered only when the
            // widget configures a `battery_soc_entity`. Independent
            // visibility gate from `has-battery`: the
            // `PowerFlowBatteryWithoutSoC` validator emits a Warning
            // (not an Error) when battery is configured without SoC, so
            // a misconfigured widget can still render the battery flow
            // lane without the SoC label.
            if view-model.has-battery-pct : Text {
                text: "soc " + round(view-model.battery-pct) + "%";
                color: Theme.text-secondary;
                font-size: Theme.font-sm;
                font-weight: Theme.font-weight-regular;
                horizontal-alignment: right;
            }

            // Home lane — rendered only when the widget configures a
            // home entity. The arrow is always "↑" (energy flowing
            // INTO the home).
            if view-model.has-home : FlowLane {
                label-text: "home";
                arrow-text: "↑";
                value-text: view-model.home-label;
                lane-color: home-color;
                idle: view-model.home-idle;
                is-available: view-model.is-available;
                period-ms: home-period-ms;
            }
        }
    }
}
