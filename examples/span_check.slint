// span_check.slint — Phase 4 kill-switch prototype for proportional span layout.
//
// SELF-CONTAINED: no imports from ui/slint/. This prototype tests Slint's
// ability to express the layout behaviors required by Phase 4's
// preferred_columns / preferred_rows schema, using the mechanisms Slint
// actually supports.
//
// # Key finding from layout investigation
//
// Slint's `GridLayout` with `colspan: N` does NOT distribute width
// proportionally to N (e.g., colspan:3 in a 4-col grid does NOT give
// 3/4 × parent_width). Instead, the spanning item's stretch is divided
// across its spanned columns, resulting in the spanning cell getting the
// same effective weight as a single non-spanning column (when all items
// have the same stretch value). The same applies to `rowspan`.
//
// The correct Slint mechanisms for proportional column/row sizing are:
//   - HorizontalLayout with `horizontal-stretch: N` for column proportions.
//   - VerticalLayout with `vertical-stretch: N` for row proportions.
// These are the mechanisms the Phase 4 packer MUST use (not GridLayout
// colspan/rowspan) to achieve the visually correct layout.
//
// # Three behaviors under test
// (per TASK-078 and docs/plans/2026-04-29-phase-4-layout.md
// `locked_decisions.span_prototype_kill_switch`)
//
//   Behavior 1 — 3-of-4 column proportion:
//     A HorizontalLayout with cell1 (horizontal-stretch:3) and cell2
//     (horizontal-stretch:1) gives cell1 a width of 3/4 × parent_width = 300px
//     on a 400px-wide window. This is the correct mechanism for
//     preferred_columns=3 in a 4-column section.
//
//   Behavior 2 — 2-of-4 row proportion:
//     A VerticalLayout with cell1 (vertical-stretch:2) and two fillers
//     (vertical-stretch:1 each) gives cell1 a height of 2/4 × section_height.
//     With a 400px-tall section, cell1 gets 200px (exactly 2/4 × 400, no
//     rounding). This is the correct mechanism for preferred_rows=2 in a
//     4-row section.
//
//   Behavior 3 — sibling sections honor independent column counts:
//     A VerticalLayout holds two sibling HorizontalLayouts:
//       - Section A: 4 equal items → col_unit = 400/4 = 100px each.
//       - Section B: 2 equal items → col_unit = 400/2 = 200px each.
//     A widget in section B must be 200px wide, NOT 100px.
//     Confirms that each section independently resolves its column widths
//     from the shared parent width.
//
// # Window geometry
//
//   Window: 400×600 physical pixels (harness sets PhysicalSize(400, 600)).
//   Scale 1.0 → 1 logical px == 1 physical px.
//
//   B1 section: y=0,   height=100px (only width is measured).
//   B2 section: y=100, height=400px (4 × 100px rows, exact arithmetic).
//   B3 section: y=500, height=100px (only widths are measured).
//
// # Performance note
//
// No animations, no interaction, no Timer elements — pure layout prototype.
// AnimationBudget wiring not needed.

export component SpanCheckWindow inherits Window {
    preferred-width: 400px;
    preferred-height: 600px;

    // ── Exposed measurement properties ─────────────────────────────────
    // The harness reads these after a single render pass.

    // Behavior 1: width of the 3/4-stretch widget in the HorizontalLayout.
    out property <length> b1-widget-width: b1-widget.width;

    // Behavior 2: height of the 2/4-stretch widget in the VerticalLayout.
    out property <length> b2-widget-height: b2-widget.height;

    // Behavior 3: width of the widget in the 2-col sibling section.
    out property <length> b3-widget-width: b3-widget.width;

    // ── Behavior 1 section (y=0, h=100px) ──────────────────────────────
    // HorizontalLayout: b1-widget has horizontal-stretch:3, filler has
    // horizontal-stretch:1. Total stretch = 4. b1-widget gets 3/4 × 400 = 300px.
    // This is the Slint mechanism for preferred_columns=3 in a 4-col section.
    //
    // Animation capped per PROFILE_DESKTOP.animation_framerate_cap: N/A
    // (this prototype has no animations).
    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 100px;

        HorizontalLayout {
            spacing: 0px;
            padding: 0px;

            b1-widget := Rectangle {
                horizontal-stretch: 3;
                background: transparent;
            }
            Rectangle {
                horizontal-stretch: 1;
                background: transparent;
            }
        }
    }

    // ── Behavior 2 section (y=100px, h=400px) ──────────────────────────
    // VerticalLayout: b2-widget has vertical-stretch:2, two fillers have
    // vertical-stretch:1 each. Total stretch = 4. b2-widget gets
    // 2/4 × 400px = 200px (exact, no rounding at this size).
    // This is the Slint mechanism for preferred_rows=2 in a 4-row section.
    Rectangle {
        x: 0px;
        y: 100px;
        width: parent.width;
        height: 400px;

        VerticalLayout {
            spacing: 0px;
            padding: 0px;

            // Spanning widget: 2 of 4 rows (vertical-stretch:2).
            b2-widget := Rectangle {
                vertical-stretch: 2;
                background: transparent;
            }
            // Row 2
            Rectangle {
                vertical-stretch: 1;
                background: transparent;
            }
            // Row 3
            Rectangle {
                vertical-stretch: 1;
                background: transparent;
            }
        }
    }

    // ── Behavior 3 section (y=500px, h=100px) ──────────────────────────
    // Two sibling HorizontalLayouts stacked in a VerticalLayout.
    // Both receive the full 400px parent width independently.
    //   Section A: 4 equal items → col_unit = 100px per item.
    //   Section B: 2 equal items → col_unit = 200px per item.
    // b3-widget is the first item of Section B and must be 200px wide.
    // If Section A's column count leaked into Section B, b3-widget would
    // wrongly be 100px. This confirms sibling-section independence.
    Rectangle {
        x: 0px;
        y: 500px;
        width: parent.width;
        height: 100px;

        VerticalLayout {
            spacing: 0px;
            padding: 0px;

            // Section A: 4 equal columns (each 100px).
            HorizontalLayout {
                spacing: 0px;
                padding: 0px;

                Rectangle { background: transparent; }
                Rectangle { background: transparent; }
                Rectangle { background: transparent; }
                Rectangle { background: transparent; }
            }

            // Section B: 2 equal columns (each 200px).
            // b3-widget at col 0 must be 200px.
            HorizontalLayout {
                spacing: 0px;
                padding: 0px;

                b3-widget := Rectangle {
                    background: transparent;
                }
                Rectangle {
                    background: transparent;
                }
            }
        }
    }
}
