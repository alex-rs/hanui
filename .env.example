# hanui environment variable schema (Phase 2.5).
#
# Copy this file to `.env.local` and fill in the values, OR run `make ha-up`
# which provisions a local Home Assistant instance in the dev VM and writes
# both lines below into `.env.local` for you. `.env.local` is gitignored and
# must NEVER be committed; the token it holds is a long-lived HA access token.
#
# After `make ha-up`, confirm the token is present without printing it:
#     grep -q HA_TOKEN .env.local && echo "token present"
#
# Do NOT `cat .env.local`, `echo $HA_TOKEN`, or otherwise surface the token
# value to stdout, shell history, or any log.

HA_URL=ws://localhost:8123/api/websocket
HA_TOKEN=<written by make ha-up — do not commit; never log>
