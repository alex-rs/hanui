// card_base.slint — shared visual chrome AND gesture-detection layer for
// every Phase 1+ tile.
//
// Provides the rounded surface, border, focus ring, press animation, and
// (TASK-060) the tap / hold / double-tap gesture-detection state machine
// that wrap the content of light_tile / sensor_tile / entity_tile.
//
// All colors are pulled from theme.slint; no inline hex literals are
// permitted in this file (CI hex-color gate, .github/workflows/ci.yml § Gate 1).
//
// Performance constraints (per docs/PHASES.md "Performance budgets" and
// src/dashboard/profiles.rs::DEFAULT_PROFILE):
//   * Press animation duration: 150 ms (never longer than the design budget).
//   * Animation framerate cap:  DEFAULT_PROFILE.animation_framerate_cap (60 fps
//     desktop). Slint's `animate` block does NOT take a framerate parameter;
//     the cap is enforced at the renderer/timer level by the Rust bridge.
//     The constant is exposed on the AnimationBudget global so the bridge
//     (TASK-015) can wire DEFAULT_PROFILE.animation_framerate_cap into the
//     timer interval at runtime — it must NOT be hardcoded in this .slint file.
//   * Active animation count gate: AnimationBudget.active-count is checked
//     against AnimationBudget.max-simultaneous. When the budget is full,
//     the press animation duration collapses to 0 ms so the card snaps to
//     the end-state without animating; the global ripple budget is preserved.
//
// Gesture layer (TASK-060):
//   * `tap`, `hold`, `double-tap` callbacks fire from a single TouchArea +
//     two Timers (hold timer, tap-promotion timer). The state machine is
//     documented in detail above the `gesture-touch` block below.
//   * All timing thresholds are READ from `GestureConfigGlobal` (TASK-059)
//     — never hardcoded. The Rust bridge (`src/ui/bridge.rs::write_gesture_config`)
//     populates the global from `crate::actions::timing::GestureConfig` at
//     startup.
//   * Per `docs/plans/2026-04-28-phase-3-actions.md` `locked_decisions.gesture_config`,
//     Slint MUST read the explicit `arm-double-tap-timer` boolean to decide
//     whether to arm the double-tap promotion timer. Slint MUST NOT infer
//     "double-tap is on" from `double-tap-max-gap-ms == 0` — the Rust side
//     pre-computes the boolean once.
//   * Risk #4 (plan): the previous tile-level `TouchArea` was a press-feedback
//     hook only. To prevent the same touch from being captured by two
//     overlapping TouchAreas (which would double-fire `tap` or fire a
//     spurious `tap` on hold-release), CardBase now owns the single
//     gesture-capture TouchArea. The tile components consume `pressed`
//     from CardBase (`out` property) instead of declaring their own
//     TouchArea.
//
// Out of scope (do not add here — see TASK-062 / Phase 3):
//   * Routing the fired callbacks through the Rust dispatcher
//     (TASK-062 owns `WidgetActionMap` + dispatcher core).
//   * Tile-specific content (icon, name, state value).
//   * More-info modal (TASK-066).

import { Theme } from "theme.slint";
import { GestureConfigGlobal } from "gesture_config.slint";

// AnimationBudget — global gate for the per-frame and total-concurrent
// animation budget. The Rust bridge (TASK-015) is responsible for:
//   1. Setting `framerate-cap` from DEFAULT_PROFILE.animation_framerate_cap
//      and using it to derive the renderer/timer interval (1000 / cap ms).
//   2. Setting `max-simultaneous` from DEFAULT_PROFILE.max_simultaneous_animations.
//   3. Incrementing `active-count` when a tile begins an animation and
//      decrementing on completion. Tiles read `active-count >= max-simultaneous`
//      to decide whether to animate or snap to the end-state.
//
// All three are `in-out` so the bridge can write them and Slint expressions
// (here and in the tile components from TASK-013) can read and mutate them.
export global AnimationBudget {
    // Frames-per-second ceiling for tile animations. Wired from
    // DEFAULT_PROFILE.animation_framerate_cap by the Rust bridge (TASK-015);
    // referenced here only via this property — never hardcoded.
    in-out property <int> framerate-cap: 60;

    // Maximum number of tile animations that may run concurrently. Wired
    // from DEFAULT_PROFILE.max_simultaneous_animations by the Rust bridge
    // (TASK-015). Cards check `active-count >= max-simultaneous` before
    // starting an animation.
    in-out property <int> max-simultaneous: 8;

    // Number of tile animations currently running. Mutated by tile press
    // handlers (TASK-013) — incremented on press start, decremented on
    // animation completion. Initialised to 0 by the bridge at startup.
    in-out property <int> active-count: 0;

    // Convenience: true when a new animation should be skipped because the
    // concurrent-animation budget is exhausted. Tiles read this to choose
    // between an animated transition (150 ms) and an immediate snap (0 ms).
    out property <bool> at-capacity: active-count >= max-simultaneous;
}

// CardBase — chrome wrapper + gesture-detection state machine used by every
// tile. Consumers place tile content inside via `@children`; CardBase handles
// the surface, border, padding, focus ring, press visual feedback, AND the
// tap/hold/double-tap gesture detection.
//
// Public surface:
//   * `pressed`  — out: true while the gesture-detection TouchArea has the
//                  press captured. Tiles read this for visual feedback.
//   * `focused`  — in: keyboard focus indicator (no callback drives it yet).
//   * `tap`      — callback: fires once per single-tap.
//   * `hold`     — callback: fires once per long-press (≥ hold-min-ms).
//   * `double-tap` — callback: fires once per pair of taps within
//                    double-tap-max-gap-ms (only when arm-double-tap-timer
//                    is true).
//
// Gesture state machine (TASK-060):
//
//   On pointer-event.down:
//     1. Record `press-started-at = animation-tick()`.
//     2. Reset `hold-fired = false`.
//     3. If `pending-tap == true` AND
//          `(animation-tick() - last-tap-at) <= double-tap-max-gap-ms * 1ms`:
//        — promote the still-pending single tap to a double-tap.
//          Stop tap-promotion-timer, clear `pending-tap`, fire `double-tap()`.
//     4. Start hold-timer (interval = hold-min-ms * 1ms).
//
//   On pointer-event.up:
//     1. Stop hold-timer.
//     2. If `hold-fired == true` — consume the up; the hold callback already
//        fired and there must be no spurious `tap` on hold-release (Risk #4).
//     3. Else if press duration `<= tap-max-ms * 1ms`:
//          - If `arm-double-tap-timer == false`: fire `tap()` synchronously.
//          - Else: record `last-tap-at`, set `pending-tap = true`,
//            start tap-promotion-timer (interval = double-tap-max-gap-ms * 1ms).
//     4. Else: press exceeded tap window but did not reach hold — drop.
//
//   On pointer-event.cancel:
//     1. Stop both timers, clear `pending-tap`, clear `hold-fired`.
//
//   On hold-timer.triggered:
//     1. self.running = false  (one-shot).
//     2. If TouchArea is still pressed: set `hold-fired = true`, fire `hold()`.
//
//   On tap-promotion-timer.triggered:
//     1. self.running = false  (one-shot).
//     2. If `pending-tap == true`: clear it and fire `tap()`.
//
// This delivers the three explicit-acceptance invariants:
//   * Single tap → exactly one `tap` (either synchronous or post-promotion).
//   * Long-press → exactly one `hold` and zero `tap` on hold-release.
//   * Two rapid downs (with arm-double-tap-timer) → exactly one `double-tap`,
//     and the still-pending first-tap is cancelled rather than emitted.
export component CardBase inherits Rectangle {
    // ── Public properties ───────────────────────────────────────────────────
    out property <bool> pressed: gesture-touch.pressed;
    in property <bool> focused: false;

    // Per-tile pending spinner gate (TASK-067). Bound by the Rust bridge
    // from `LiveStore::pending_for_widget(widget_id) -> bool` (the
    // cross-owner read API locked in `locked_decisions.pending_state_read_api`
    // and shipped by TASK-064). When `true`, the small spinner overlay below
    // is shown in the top-right of the card while the optimistic action is
    // in flight; when `false`, the spinner is removed from the item tree
    // entirely (the `if` block produces nothing). Slint must not invent a
    // parallel pending-state path — every consumer reads from this property,
    // and the property is fed solely from `pending_for_widget` (Risk #14).
    in property <bool> pending: false;

    // ── Gesture callbacks (TASK-060) ────────────────────────────────────────
    // Wired by the Rust bridge / dispatcher in TASK-062. CardBase fires them;
    // it does NOT route them anywhere — that is dispatcher territory.
    callback tap();
    callback hold();
    callback double-tap();

    // ── Internal gesture state ──────────────────────────────────────────────
    // `press-started-at` is the animation-tick value at the most recent
    // pointer-down. Used to classify the corresponding pointer-up as tap or
    // (timed-out) drop.
    property <duration> press-started-at: 0ms;
    // `last-tap-at` is the animation-tick value at the most recent
    // tap-up. Reset only by a tap firing or a cancel.
    property <duration> last-tap-at: 0ms;
    // `pending-tap` is true between a tap-up and the tap-promotion-timer
    // firing (or being cancelled by a follow-up down). Drives the
    // single-tap-vs-double-tap branch on the next down.
    property <bool> pending-tap: false;
    // `hold-fired` is true once the hold-timer has fired for the in-flight
    // press. Suppresses the tap branch on the corresponding up so a hold
    // never produces a spurious tap (Risk #4 explicit acceptance).
    property <bool> hold-fired: false;

    // ── Chrome (surface, border, radius) ────────────────────────────────────
    // Background brightens to `elevated` while pressed for the press feedback.
    // The border collapses into an accent-coloured focus ring when either
    // pressed or focused, giving keyboard and touch users the same affordance.
    background: pressed ? Theme.elevated : Theme.surface;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: (pressed || focused) ? Theme.accent : Theme.elevated;

    // ── Press animation (150 ms, gated by AnimationBudget) ──────────────────
    // Slint resolves `duration` for each animation kick-off. When the global
    // concurrent-animation budget is exhausted, `at-capacity` is true and the
    // duration collapses to 0 ms — the property change still applies, but
    // the renderer skips the interpolation. This implements the "snap to
    // end-state without animating" requirement from TASK-012 AC #4.
    //
    // Cap of 150 ms is the design ceiling; do not raise without a Phase 1
    // design review.
    animate background {
        duration: AnimationBudget.at-capacity ? 0ms : 150ms;
    }
    animate border-color {
        duration: AnimationBudget.at-capacity ? 0ms : 150ms;
    }

    // ── Content slot ────────────────────────────────────────────────────────
    // A VerticalLayout owns the padding so tile children inherit it without
    // each tile re-declaring the spacing. Rectangle itself has no `padding`
    // property in Slint; padding is a layout-container concern.
    VerticalLayout {
        padding: Theme.space-3;
        @children
    }

    // ── Gesture-capture TouchArea (TASK-060) ────────────────────────────────
    // Single pointer-capture region for the entire card. Sits AFTER the
    // content layout in the item tree so it overlays it (Slint paints later
    // children on top, and the TouchArea is intentionally transparent — its
    // job is event capture, not rendering). This is the ONLY TouchArea on
    // the card; tile files consume `pressed` from CardBase rather than
    // declaring their own TouchArea (Risk #4 mitigation).
    gesture-touch := TouchArea {
        // Fill the card via Slint's TouchArea default sizing.
        mouse-cursor: pointer;

        pointer-event(event) => {
            if (event.kind == PointerEventKind.down) {
                root.press-started-at = animation-tick();
                root.hold-fired = false;
                // Detect the second-down side of a double-tap. We branch on
                // `pending-tap` (set only when arm-double-tap-timer is true)
                // — there is no zero-gap inference path. The gap check uses
                // duration arithmetic so the int * 1ms multiplier promotes
                // `double-tap-max-gap-ms` to a comparable duration.
                if (root.pending-tap
                    && (animation-tick() - root.last-tap-at)
                       <= GestureConfigGlobal.double-tap-max-gap-ms * 1ms) {
                    tap-promotion-timer.running = false;
                    root.pending-tap = false;
                    root.double-tap();
                }
                hold-timer.running = true;
            } else if (event.kind == PointerEventKind.up) {
                hold-timer.running = false;
                if (root.hold-fired) {
                    // Hold already fired — DO NOT also emit `tap` on the
                    // corresponding release. This is the spurious-tap
                    // suppression Risk #4 names explicitly.
                    root.hold-fired = false;
                } else if ((animation-tick() - root.press-started-at)
                           <= GestureConfigGlobal.tap-max-ms * 1ms) {
                    if (GestureConfigGlobal.arm-double-tap-timer) {
                        // Arm the promotion timer: tap fires after the gap
                        // unless a second down arrives within the window.
                        root.last-tap-at = animation-tick();
                        root.pending-tap = true;
                        tap-promotion-timer.running = true;
                    } else {
                        // No double-tap path — fire synchronously. Slint
                        // never infers double-tap from a zero gap; this
                        // branch is reached only when the explicit boolean
                        // is false (locked_decisions.gesture_config).
                        root.tap();
                    }
                }
                // Press exceeded tap-max-ms but never reached hold-min-ms:
                // intentional drop. The user lifted in the dead zone.
            } else if (event.kind == PointerEventKind.cancel) {
                hold-timer.running = false;
                tap-promotion-timer.running = false;
                root.pending-tap = false;
                root.hold-fired = false;
            }
        }
    }

    // ── Hold timer (TASK-060) ───────────────────────────────────────────────
    // One-shot. Armed on pointer-down, disarmed on pointer-up or cancel.
    // Fires `hold()` only if the TouchArea is still pressed at trigger time
    // (defensive: if the user lifted *exactly* between pointer-event.up
    // running `running = false` and the timer firing one tick later, we do
    // not want a hold against an already-released press).
    hold-timer := Timer {
        interval: GestureConfigGlobal.hold-min-ms * 1ms;
        running: false;
        triggered => {
            self.running = false;
            if (gesture-touch.pressed) {
                root.hold-fired = true;
                root.hold();
            }
        }
    }

    // ── Tap-promotion timer (TASK-060) ──────────────────────────────────────
    // One-shot. Armed on a tap-classified pointer-up when
    // `arm-double-tap-timer == true`. If a second down arrives within
    // `double-tap-max-gap-ms`, the down-handler cancels this timer and
    // fires `double-tap` instead. Otherwise this timer fires `tap`.
    tap-promotion-timer := Timer {
        interval: GestureConfigGlobal.double-tap-max-gap-ms * 1ms;
        running: false;
        triggered => {
            self.running = false;
            if (root.pending-tap) {
                root.pending-tap = false;
                root.tap();
            }
        }
    }

    // ── Pending spinner overlay (TASK-067) ──────────────────────────────────
    // Small spinner anchored in the top-right corner. Visible only while
    // `root.pending == true`, which is bound to
    // `LiveStore::pending_for_widget` — the cross-owner read API from
    // TASK-064 per locked_decisions.pending_state_read_api. The `if`
    // block collapses the spinner out of the item tree when
    // `pending == false` so the renderer does no extra work on the
    // steady-state path.
    //
    // Animation: `animation-tick()` is Slint's monotonic clock — a
    // `<duration>` value that increases continuously from a baseline at
    // load. Deriving `phase` as `(animation-tick() / 1200ms) * 360deg`
    // mod 360deg gives a free-running angle that loops every 1.2 s
    // without any per-property animation declaration. This is the
    // idiomatic Slint pattern for infinite rotations and avoids the
    // `animate` "from-prev-value" pitfall (a property declared at
    // 360deg with `animate { ... }` interpolates from 360deg to 360deg
    // — visibly stuck on first paint).
    //
    // A small marker dot's `x` / `y` are derived from `cos(phase)` /
    // `sin(phase)` around the ring centre, producing a visible orbit.
    // The ring outline behind the dot is a stationary Rectangle with a
    // thick accent border.
    //
    // Performance contract: when `AnimationBudget.at-capacity` is true,
    // the marker dot snaps to a fixed phase (`0deg`) so the renderer
    // does not redraw the dot every animation tick — preserving the
    // global concurrent-animation budget. The dot remains visible (the
    // spinner still indicates "pending"), it just does not orbit.
    //
    // Why a marker-dot orbit rather than a `rotation-angle` property:
    // Slint's `rotation-angle` exists on `Image` only (not on
    // `Rectangle`); using `cos`/`sin` on the marker's position keeps
    // the spinner using primitives any tile can render with the
    // software backend (no SVG / image asset).
    //
    // When `pending` flips back to false the entire `if` subtree is
    // removed, dropping every binding on `animation-tick()` cleanly —
    // there is no orphaned timer.
    if root.pending : Rectangle {
        // Anchored top-right with `space-2` inset.
        x: parent.width - self.width - Theme.space-2;
        y: Theme.space-2;
        width: 16px;
        height: 16px;

        // Free-running phase angle. `animation-tick()` returns a
        // monotonic `<duration>`; dividing by the period and
        // multiplying by 360deg gives the current rotation angle.
        // The expression is re-evaluated every animation frame so the
        // dot's position updates without an explicit `animate` block.
        property <angle> phase: AnimationBudget.at-capacity
            ? 0deg
            : (mod(animation-tick() / 1ms, 1200) / 1200) * 360deg;

        // Ring outline. A Rectangle with a thick accent border and a
        // transparent fill is the simplest stationary visual primitive
        // that reads as a "spinner ring".
        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            border-radius: parent.width / 2;
            border-width: 2px;
            border-color: Theme.accent;
            background: transparent;
        }

        // Rotation marker dot — gives the ring a visible orientation so
        // the user perceives motion. Position is derived from `phase`
        // via cos/sin so the dot orbits the ring centre. The radius is
        // (parent.width / 2 - 2px) so the dot sits inside the ring's
        // outer edge.
        Rectangle {
            // Center of the spinner area is parent.width/2, parent.height/2.
            // Orbit radius is (parent.width/2 - 2px) so the dot stays
            // inside the ring outline. Subtract self.width/2 / self.height/2
            // so the dot's own centre sits on the orbit, not its top-left.
            x: parent.width / 2 - self.width / 2 + cos(parent.phase - 90deg) * (parent.width / 2 - 2px) / 1px * 1px;
            y: parent.height / 2 - self.height / 2 + sin(parent.phase - 90deg) * (parent.height / 2 - 2px) / 1px * 1px;
            width: 4px;
            height: 4px;
            border-radius: 2px;
            background: Theme.accent;
        }
    }
}
