// view_switcher.slint — density-gated view navigation (Phase 4, TASK-086).
//
// # Component overview
//
// `ViewSwitcher` renders one of two navigation modes based on `view-count` and
// `density`, and optionally overlays an edge-swipe gesture handler when
// `touch-input` is true:
//
//   Mode selection (per locked_decisions.density_mode_behavior):
//   - view-count ≤ 2  OR  density ≠ "compact"  →  TabStrip
//   - view-count ≥ 3  AND  density == "compact"  →  Dropdown
//
//   Swipe overlay (per locked_decisions.view_switcher_touch_gating):
//   - touch-input == true  →  EdgeSwipeLayer instantiated (responds to
//                             horizontal drag at the left/right edge regions)
//   - touch-input == false →  EdgeSwipeLayer NOT in the Slint tree at all
//
// # Swipe gesture parameters
//
//   Drag threshold: 80px horizontal displacement OR velocity > 0.5 px/ms
//   Direction: swipe-left → next view (view-index + 1); swipe-right →
//              previous view (view-index - 1).
//   Boundary clamping: swipe past the first/last view emits no view-changed.
//
// # Framerate cap
//
//   Animation capped at DEFAULT_PROFILE.animation_framerate_cap per
//   PHASES.md performance budgets. The global AnimationBudget drives the
//   press-feedback animation on tab buttons (inherited from CardBase's
//   budget gate in card_base.slint). No additional animation is introduced
//   here; the density-mode switch is a property re-evaluation, not an
//   animated transition.
//
// # Theme tokens
//
//   All colors must reference Theme tokens. No inline hex literals.
//   CI hex-color gate enforces this per docs/dev/ci-pipeline.md Gate 1.
//
// # Property contract (TASK-086)
//
//   The Rust bridge (src/ui/bridge.rs) populates these once per Dashboard
//   load:
//     views         - flat ordered list of ViewMeta structs (id, title)
//     active-view-index - zero-based index of the currently-rendered view
//     density       - string "compact" | "regular" | "spacious"
//     touch-input   - mirrors DeviceProfile.touch_input
//
//   Output:
//     callback view-changed(int) — emits the new view index (zero-based)

import { Theme } from "theme.slint";

// ViewMeta — per-view navigation label, passed as a flat array.
//
// Slint kebab-case field names; Rust bridge uses snake_case equivalents
// (generated automatically by the Slint compiler):
//   id    -> id
//   title -> title
export struct ViewMeta {
    id: string,
    title: string,
}

// ViewSwitcher — top-level component.
//
// Performance contract:
//   No per-frame work. Mode selection is a pure property expression
//   re-evaluated when density or view-count changes. The TabStrip /
//   Dropdown renderings are each in a conditional `if` branch, so only
//   the active subtree is instantiated at any given time.
//   Animation capped at DEFAULT_PROFILE.animation_framerate_cap per
//   PHASES.md:58 (inherited from AnimationBudget in card_base.slint).
export component ViewSwitcher inherits Rectangle {
    // ── Input properties ─────────────────────────────────────────────────────
    //
    // views: ordered list of navigation entries. Length determines whether a
    //        tab strip or dropdown is rendered.
    in property <[ViewMeta]> views;

    // view-count: derived from views.length.
    in property <int> view-count: root.views.length;

    // active-view-index: zero-based index of the currently-shown view.
    //                    The bridge writes this; the tab strip highlights the
    //                    matching tab, the dropdown shows the matching title.
    in property <int> active-view-index: 0;

    // density: mirrors DeviceProfile.density as a string.
    //          Values: "compact" | "regular" | "spacious"
    //          Default "regular" — matches PROFILE_DESKTOP.density (Spacious
    //          renders identically to Regular in Phase 4 per the plan; bridge
    //          maps both Spacious and Regular to "regular" for simplicity, or
    //          passes the literal string — either works because the `if`
    //          condition checks only for "compact").
    in property <string> density: "regular";

    // touch-input: mirrors DeviceProfile.touch_input.
    //              When false, the EdgeSwipeLayer is NOT instantiated (the
    //              entire subtree is absent from the Slint element tree).
    //              When true, the EdgeSwipeLayer is instantiated and responds
    //              to horizontal pointer drags across the edge zones.
    //              Per locked_decisions.view_switcher_touch_gating: the dev VM
    //              (desktop profile) has touch_input=false, so the swipe
    //              handler is never instantiated in normal dev runs.
    in property <bool> touch-input: false;

    // ── Output callback ──────────────────────────────────────────────────────
    //
    // view-changed(index): emitted when the user selects a different view.
    //   `index` is the new zero-based view index (0 ≤ index < view-count).
    //   The Rust bridge translates this into a Slint property write on the
    //   next frame (updating active-view-index and pushing the tile model for
    //   the selected view).
    callback view-changed(int);

    // ── Component background ─────────────────────────────────────────────────
    background: Theme.surface;

    // ── Tab strip (default mode) ─────────────────────────────────────────────
    //
    // Rendered when: view-count ≤ 2  OR  density ≠ "compact"
    //
    // Layout: HorizontalLayout, one button per view, each stretching equally
    // across the available width. The active tab shows an accent-colored
    // bottom border; inactive tabs show muted text.
    //
    // Per locked_decisions.density_mode_behavior:
    //   ≤2 views        → TabStrip always (regardless of density)
    //   ≥3 views, Regular/Spacious → TabStrip
    //   ≥3 views, Compact          → Dropdown (the else branch below)
    if root.view-count <= 2 || root.density != "compact" : HorizontalLayout {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        spacing: 0px;
        padding: 0px;

        for view[i] in root.views : Rectangle {
            // Each tab is a proportionally-equal fraction of the width.
            // No fixed width — stretch fills naturally via HorizontalLayout.
            background: transparent;
            height: parent.height;

            // Active-tab bottom accent bar (accent-colored, 2px height).
            // Positioned at the bottom edge of the tab rectangle.
            if i == root.active-view-index : Rectangle {
                x: 0px;
                y: parent.height - 2px;
                width: parent.width;
                height: 2px;
                background: Theme.accent;
            }

            // Tab label. Active tab uses text-primary; inactive uses
            // text-secondary (muted). No inline hex — Theme tokens only.
            Text {
                text: view.title;
                color: i == root.active-view-index
                    ? Theme.text-primary
                    : Theme.text-secondary;
                font-size: Theme.font-md;
                font-weight: i == root.active-view-index
                    ? Theme.font-weight-medium
                    : Theme.font-weight-regular;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }

            // Touch / click area for tab selection.
            tab-touch := TouchArea {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                clicked => {
                    root.view-changed(i);
                }
            }
        }
    }

    // ── Dropdown picker (compact mode, ≥3 views) ─────────────────────────────
    //
    // Rendered when: view-count ≥ 3 AND density == "compact"
    //
    // Layout: a single Rectangle row containing:
    //   - The active view title (left-aligned Text)
    //   - A chevron/arrow indicator (right-aligned Text)
    // A TouchArea below both triggers toggling a private `dropdown-open`
    // property. When open, a VerticalLayout of view items overlays below.
    //
    // Per locked_decisions.density_mode_behavior: Compact + ≥3 views → dropdown.
    if root.view-count >= 3 && root.density == "compact" : Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: Theme.elevated;

        // Private state: whether the dropdown list is expanded.
        // This is a purely local UI concern — not exposed as an `in`
        // property and not wired to the Rust bridge. The dropdown collapses
        // automatically when the user selects a view (view-changed fires and
        // the bridge writes a new active-view-index).
        property <bool> dropdown-open: false;

        // Header row: active view title + chevron indicator.
        header := Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: transparent;

            // Active view title (left-padded by Theme.space-3).
            Text {
                x: Theme.space-3;
                y: 0px;
                width: parent.width - Theme.space-6 - Theme.space-3;
                height: parent.height;
                text: root.active-view-index < root.views.length
                    ? root.views[root.active-view-index].title
                    : "";
                color: Theme.text-primary;
                font-size: Theme.font-md;
                font-weight: Theme.font-weight-medium;
                horizontal-alignment: left;
                vertical-alignment: center;
                overflow: elide;
            }

            // Chevron indicator: "▾" when closed, "▴" when open.
            Text {
                x: parent.width - Theme.space-6;
                y: 0px;
                width: Theme.space-6;
                height: parent.height;
                text: dropdown-open ? "▴" : "▾";
                color: Theme.text-secondary;
                font-size: Theme.font-sm;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            // TouchArea covering the entire header to open/close the list.
            TouchArea {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                clicked => {
                    dropdown-open = !dropdown-open;
                }
            }
        }

        // Dropdown list overlay — visible only when dropdown-open == true.
        // Rendered below the header (y = parent.height) via absolute
        // positioning, overlapping content beneath the switcher. Phase 4
        // does not implement proper z-layering for the overlay; it relies
        // on the ViewSwitcher being at the top of the window stack so the
        // list drops "down" into the content area visually.
        if dropdown-open : Rectangle {
            x: 0px;
            y: parent.height;
            width: parent.width;
            // Height: one row per view, each Theme.space-6 (32px) tall.
            // Bounded to a max of 5 visible rows; Phase 4 does not add
            // an inner scroll — the validator caps view count per
            // max_widgets_per_view and practical dashboards have ≤8 views.
            height: root.view-count * Theme.space-6;
            background: Theme.elevated;

            VerticalLayout {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                spacing: 0px;
                padding: 0px;

                for view[i] in root.views : Rectangle {
                    height: Theme.space-6;
                    background: i == root.active-view-index
                        ? Theme.accent
                        : transparent;

                    Text {
                        x: Theme.space-3;
                        y: 0px;
                        width: parent.width - Theme.space-3;
                        height: parent.height;
                        text: view.title;
                        color: i == root.active-view-index
                            ? Theme.background
                            : Theme.text-primary;
                        font-size: Theme.font-md;
                        font-weight: i == root.active-view-index
                            ? Theme.font-weight-medium
                            : Theme.font-weight-regular;
                        horizontal-alignment: left;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    TouchArea {
                        x: 0px;
                        y: 0px;
                        width: parent.width;
                        height: parent.height;
                        clicked => {
                            root.view-changed(i);
                            dropdown-open = false;
                        }
                    }
                }
            }
        }
    }

    // ── Edge-swipe overlay (touch-input gated) ───────────────────────────────
    //
    // Per locked_decisions.view_switcher_touch_gating:
    //   touch-input == true  → this block IS in the Slint element tree.
    //   touch-input == false → this block IS NOT in the tree (the `if`
    //                           condition is false; Slint does not instantiate
    //                           the subtree at all).
    //
    // The EdgeSwipeLayer covers two touch zones at the left and right edges:
    //   - Left zone:  x ∈ [0, 48px] — a right-swipe gesture (prev view).
    //   - Right zone: x ∈ [width-48px, width] — a left-swipe gesture (next view).
    //
    // Gesture detection:
    //   State machine tracks pressed position (pressed-x, pressed-y) and
    //   accumulated horizontal displacement as the pointer moves.
    //   Threshold: |Δx| ≥ 80px OR velocity > 0.5 px/ms.
    //   Phase 4 velocity approximation: we use displacement-only threshold
    //   (80px) for simplicity; velocity estimation requires tracking
    //   timestamps and is deferred to Phase 5 SBC refinement.
    //
    // Animation framerate cap:
    //   No animation in this layer. The swipe gesture fires view-changed
    //   synchronously on PointerReleased; the bridge then schedules a
    //   property write on the next frame within the normal
    //   DEFAULT_PROFILE.animation_framerate_cap budget.
    //   Animation capped at DEFAULT_PROFILE.animation_framerate_cap per
    //   PHASES.md:58.
    if root.touch-input : Rectangle {
        // The swipe layer sits above all content; it is transparent and
        // does not intercept taps in the interior (only within the 48px
        // edge bands, where TouchAreas are placed).
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: transparent;

        // Left-edge swipe zone (right-swipe → previous view).
        // Private gesture state:
        property <bool> left-pressed: false;
        property <float> left-press-x: 0.0;
        property <float> left-current-x: 0.0;

        left-zone := TouchArea {
            x: 0px;
            y: 0px;
            width: 48px;
            height: parent.height;
            pointer-event(event) => {
                if event.kind == PointerEventKind.down {
                    left-pressed = true;
                    left-press-x = self.mouse-x / 1px;
                    left-current-x = self.mouse-x / 1px;
                } else if event.kind == PointerEventKind.up {
                    if left-pressed {
                        // displacement > 0 means right-swipe (finger moved right)
                        // → navigate to previous view.
                        if left-current-x - left-press-x >= 80.0 {
                            if root.active-view-index > 0 {
                                root.view-changed(root.active-view-index - 1);
                            }
                        }
                    }
                    left-pressed = false;
                } else if event.kind == PointerEventKind.move {
                    if left-pressed {
                        left-current-x = self.mouse-x / 1px;
                    }
                }
            }
        }

        // Right-edge swipe zone (left-swipe → next view).
        property <bool> right-pressed: false;
        property <float> right-press-x: 0.0;
        property <float> right-current-x: 0.0;

        right-zone := TouchArea {
            x: parent.width - 48px;
            y: 0px;
            width: 48px;
            height: parent.height;
            pointer-event(event) => {
                if event.kind == PointerEventKind.down {
                    right-pressed = true;
                    right-press-x = self.mouse-x / 1px;
                    right-current-x = self.mouse-x / 1px;
                } else if event.kind == PointerEventKind.up {
                    if right-pressed {
                        // displacement < 0 means left-swipe (finger moved left)
                        // → navigate to next view.
                        if right-press-x - right-current-x >= 80.0 {
                            if root.active-view-index < root.view-count - 1 {
                                root.view-changed(root.active-view-index + 1);
                            }
                        }
                    }
                    right-pressed = false;
                } else if event.kind == PointerEventKind.move {
                    if right-pressed {
                        right-current-x = self.mouse-x / 1px;
                    }
                }
            }
        }
    }
}

// ViewSwitcherWindow — Window-rooted wrapper for headless test harness use.
//
// Purpose: `ViewSwitcher` inherits Rectangle (not Window), so the Slint
// compiler does not emit a top-level `ComponentHandle` for it alone.
// `ViewSwitcherWindow` wraps it in a Window so tests in `src/ui/bridge.rs`
// can instantiate it under the headless `MinimalSoftwareWindow` platform via
// `ViewSwitcherWindow::new()`.
//
// Properties mirror `ViewSwitcher` exactly; they are forwarded verbatim so
// the test surface matches the production component surface 1:1.
//
// Output callback `view-changed(int)` is forwarded; additionally, an
// `out property <int> last-view-changed-index` captures the last emitted
// index for assertions without requiring a Rust-side counter.
//
// Performance: no animation in this wrapper. Animation capped at
// DEFAULT_PROFILE.animation_framerate_cap per PHASES.md:58.
export component ViewSwitcherWindow inherits Window {
    title: "ViewSwitcherWindow";
    preferred-width: 480px;
    preferred-height: 48px;
    background: Theme.background;

    // ── Forwarded input properties ────────────────────────────────────────────
    in property <[ViewMeta]> views;
    in property <int> active-view-index: 0;
    in property <string> density: "regular";
    in property <bool> touch-input: false;

    // ── Observed output ───────────────────────────────────────────────────────
    // view-changed(int): forwarded from the inner ViewSwitcher. Bridge tests
    // capture the emitted index via the Rc<Cell<i32>> counter pattern per
    // locked_decisions.slint_swipe_injection_path.
    callback view-changed(int);

    // last-view-changed-index: captures the most recent view-changed payload
    // so tests can assert without a Rust counter closure (simpler pattern for
    // property-only assertions such as density-mode table tests).
    out property <int> last-view-changed-index: -1;

    switcher := ViewSwitcher {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        views: root.views;
        active-view-index: root.active-view-index;
        density: root.density;
        touch-input: root.touch-input;
        view-changed(idx) => {
            root.last-view-changed-index = idx;
            root.view-changed(idx);
        }
    }
}
